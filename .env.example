# EmailJS config — get these from https://dashboard.emailjs.com after signup.
# See README "Wiring the contact form" section for full setup steps.
# These are safe to expose in the browser bundle (EmailJS's public key is
# designed to be public — that's how the SDK works), but still keep them
# in env vars rather than hardcoded so you can swap accounts without a code change.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
